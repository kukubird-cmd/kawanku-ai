# KawanKu AI Backend Configuration

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True

# ============================================
# Database Configuration
# ============================================
# SQLite (Development)
DATABASE_URL=sqlite:///kawanku_ai.db

# PostgreSQL (Production - uncomment to use)
# DATABASE_URL=postgresql://user:password@localhost/kawanku_ai

# ============================================
# Gemini AI Configuration (Optional)
# ============================================
# For AI responses in chat
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:5000,http://localhost:5001

# ============================================
# Email Configuration (Optional)
# ============================================
# For sending alerts to counselors
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ============================================
# Security
# ============================================
# In production, set to False
ENABLE_DEBUG_MODE=True

# Password for encrypting sensitive data
ENCRYPTION_KEY=your-encryption-key-32-chars-min
